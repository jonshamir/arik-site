---
layout: base.njk
pagination:
  data: papers
  size: 1
  alias: paper
  addAllPagesToCollections: true
permalink: /papers/{{ paper.slug }}/
eleventyComputed:
  title: "{{ paper.title }} — Ariel Shamir"
---

<article class="paper-detail">
  <p class="paper-authors">{{ paper.authors | join(' · ') }}</p>
  <h1>{{ paper.title }}</h1>
  <p class="paper-venue">{{ paper.venue }} ({{ paper.year }})</p>

  <div class="paper-categories">
    {% for cat in paper.categories %}
      <a href="/categories/{{ cat | toSlug }}/" class="category-tag"
        >{{ cat }}</a
      >
    {% endfor %}
  </div>

  <div class="paper-links">
    {% if paper.paperLink %}
      <a href="{{ paper.paperLink }}" class="btn">Paper PDF</a>
    {% endif %}
    {% if paper.videoLink %}
      <a href="{{ paper.videoLink }}" class="btn">Video</a>
    {% endif %}
    {% if paper.projectLink %}
      <a href="{{ paper.projectLink }}" class="btn">Project Page</a>
    {% endif %}
  </div>

  <div class="paper-abstract">
    <h2>Abstract</h2>
    <p>{{ paper.abstract }}</p>
  </div>

  {% if paper.overviewImage %}
    <div class="paper-overview-image">
      <img src="{{ paper.overviewImage }}" alt="{{ paper.title }}" />
    </div>
  {% endif %}
</article>
