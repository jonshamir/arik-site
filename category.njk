---
layout: base.njk
pagination:
  data: collections.papersByCategory
  size: 1
  alias: category
permalink: /categories/{{ category.slug }}/
eleventyComputed:
  title: "{{ category.name }} — Ariel Shamir"
---

<section class="category-page">
  <h1>{{ category.name }}</h1>
  <p>
    {{ category.papers.length }} paper{{ "s" if category.papers.length != 1 }}
    in this category.
  </p>

  {% for paper in category.papers | sort(true, false, 'year') %}
    {% include "paper-card.njk" %}
  {% endfor %}
</section>
